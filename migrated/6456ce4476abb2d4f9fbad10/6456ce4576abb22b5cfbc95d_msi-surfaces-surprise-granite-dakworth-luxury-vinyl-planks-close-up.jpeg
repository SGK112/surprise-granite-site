<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 600 600" preserveAspectRatio="xMidYMid slice" role="img" aria-label="Surprise Granite — image not available">
  <defs>
    <linearGradient id="sg-card-grad" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="#f8fafc"/>
      <stop offset="50%" stop-color="#e2e8f0"/>
      <stop offset="100%" stop-color="#cbd5e1"/>
    </linearGradient>
    <pattern id="sg-card-grain" x="0" y="0" width="100" height="100" patternUnits="userSpaceOnUse">
      <circle cx="20" cy="30" r="1" fill="#cca600" opacity="0.06"/>
      <circle cx="70" cy="60" r="1.4" fill="#1a1a2e" opacity="0.05"/>
      <circle cx="40" cy="80" r="0.8" fill="#cca600" opacity="0.05"/>
    </pattern>
  </defs>
  <rect width="600" height="600" fill="url(#sg-card-grad)"/>
  <rect width="600" height="600" fill="url(#sg-card-grain)"/>
  <g transform="translate(300 300)" fill="#94a3b8" font-family="-apple-system,BlinkMacSystemFont,system-ui,sans-serif" text-anchor="middle">
    <text y="-6" font-size="22" font-weight="700" letter-spacing="2" opacity="0.55">SURPRISE GRANITE</text>
    <text y="22" font-size="13" font-weight="500" letter-spacing="1" opacity="0.45">Premium quartz · granite · marble</text>
  </g>
</svg>
